## ---- src/Makevars ----
# Force modern C++ on the compile line
PKG_CXXFLAGS += -std=gnu++17     # (or: CXX_STD = CXX17)
PKG_CXXFLAGS += -Wfatal-errors -fmax-errors=1 -ftemplate-backtrace-limit=5
# Add the package headers path and RcppArmadillo flags
PKG_CPPFLAGS += -I../inst/include $(RCPP_ARMA_CXXFLAGS)

# Link libs
PKG_LIBS     += $(RCPP_ARMA_LIBS) -lgsl -lgslcblas

