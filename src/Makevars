CXX_STD = CXX17

# RcppArmadillo headers, package headers, bundled GSL headers, and defines
PKG_CPPFLAGS = -I../inst/include $(RCPP_ARMA_CXXFLAGS) -Igsl_bundled -DUSE_FAST_PNORM -DRCPP_NO_R_HEADERS_CHECK -DARMA_DONT_PRINT_FAST_MATH_WARNING -DR_NO_REMAP

# Link libs (GSL compiled in via gsl_bundled.c — no system GSL needed)
PKG_LIBS = $(RCPP_ARMA_LIBS)
