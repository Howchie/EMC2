## ---- src/Makevars ----
# Force modern C++ on the compile line
PKG_CXXFLAGS += -std=gnu++17 -Wfatal-errors -fmax-errors=1 -ftemplate-backtrace-limit=5    # (or: CXX_STD = CXX17)

# Performance flags matching upstream oo_refactor_simd branch:
#   -O3           : full optimization (upstream uses -O3; R defaults to -O2)
#   -march=native : enables AVX2/SSE4 SIMD intrinsics on the build machine
#   -ffast-math   : relaxes IEEE strictness, allows autovectorization of FP loops
#   -fno-math-errno: avoids errno checks in math functions (pairs with -ffast-math)
#   -DUSE_FAST_PNORM: enables the fast standard-normal CDF approximation in Wald/RDM code
# NOTE: R's ALL_CXXFLAGS = PKG_CXXFLAGS ... CXXFLAGS, so CXXFLAGS (-O2) comes last
# and overrides PKG_CXXFLAGS. The `override` directive forces our flags to append
# *after* Makeconf's CXXFLAGS assignment, so the last -O wins.
override CXXFLAGS += -O3 -march=native -ffast-math -fno-math-errno -DUSE_FAST_PNORM

# Add the package headers path, RcppArmadillo flags, and bundled GSL headers.
# -Igsl_bundled makes <config.h> and <gsl/...> resolve to src/gsl_bundled/
PKG_CPPFLAGS += -I../inst/include $(RCPP_ARMA_CXXFLAGS) -Wfatal-errors -fmax-errors=1 -Igsl_bundled -DRCPP_NO_R_HEADERS_CHECK -DARMA_DONT_PRINT_FAST_MATH_WARNING

# Link libs — no -lgsl/-lgslcblas needed; GSL is compiled in via gsl_bundled.c
PKG_LIBS     += $(RCPP_ARMA_LIBS)
