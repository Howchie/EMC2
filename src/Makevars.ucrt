PKG_CXXFLAGS += -std=gnu++17 -Wfatal-errors -fmax-errors=1 -ftemplate-backtrace-limit=5
override CXXFLAGS += -O3 -march=native -ffast-math -fno-math-errno -DUSE_FAST_PNORM
PKG_CPPFLAGS = $(RCPP_ARMA_CXXFLAGS) -I../inst/include -Igsl_bundled -Wfatal-errors -fmax-errors=1 -DRCPP_NO_R_HEADERS_CHECK -DARMA_DONT_PRINT_FAST_MATH_WARNING -DUSE_FAST_PNORM -DR_NO_REMAP
# GSL integration is compiled in via gsl_bundled.c — no system GSL needed
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
