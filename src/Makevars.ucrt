CXX_STD = CXX17

PKG_CPPFLAGS = $(RCPP_ARMA_CXXFLAGS) -I../inst/include -Igsl_bundled -DUSE_FAST_PNORM -DRCPP_NO_R_HEADERS_CHECK -DARMA_DONT_PRINT_FAST_MATH_WARNING -DR_NO_REMAP

# GSL integration is compiled in via gsl_bundled.c — no system GSL needed
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
