dat <- make_data(p_vector,designLBA,n_trials=500, UC=3)
table(dat$S, dat$Difficulty)
Cfun <- function(d) as.numeric(d$S)==as.numeric(d$R)
Rtfun <- function(d){ d$rt[d$rt==Inf]=NA; d$rt}
tapply(Cfun(dat),dat[,c("S","Difficulty")],function(x){mean(x,na.rm=TRUE)})
tapply(Rtfun(dat),dat[,c("S","Difficulty")],function(x){mean(x,na.rm=TRUE)})
# Check likelihood
dadmLBA <- EMC2:::design_model(dat,designLBA)
pars <- EMC2:::get_pars_matrix(p_vector, dadmLBA, model = attr(dadmLBA, "model")())
#library(parallel)
profile_plot_test(dat,designLBA,p_vector,n_cores=1,layout=c(2,3)) # good
library(parallel)
profile_plot_test(dat,designLBA,p_vector,n_cores=1,layout=c(2,3)) # good
p_vector
p_vector[1:length(p_vector)] <- c(log(2),log(3), 1, 3, 1.5, 2.5, log(1.01), log(.75),log(.2))
# Make square data so can remove pm in RACE = 2
dat <- make_data(p_vector,designLBA,n_trials=500, UC=3)
table(dat$S, dat$Difficulty)
Cfun <- function(d) as.numeric(d$S)==as.numeric(d$R)
Rtfun <- function(d){ d$rt[d$rt==Inf]=NA; d$rt}
tapply(Cfun(dat),dat[,c("S","Difficulty")],function(x){mean(x,na.rm=TRUE)})
tapply(Rtfun(dat),dat[,c("S","Difficulty")],function(x){mean(x,na.rm=TRUE)})
# Check likelihood
dadmLBA <- EMC2:::design_model(dat,designLBA)
pars <- EMC2:::get_pars_matrix(p_vector, dadmLBA, model = attr(dadmLBA, "model")())
library(parallel)
profile_plot_test(dat,designLBA,p_vector,n_cores=1,layout=c(2,3)) # good
unloadNamespace(EMC2)
unloadNamespace('EMC2')
devtools::install_local()
devtools::install_local(force=TRUE)
remove.packages("EMC2")
devtools::install_local(force=TRUE)
