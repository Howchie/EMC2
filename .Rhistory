# emc <- fit(emc,cores_per_chain = 3)
# recovery(emc,p_vector)
data=dat
design=designLBA
dadm <- EMC2:::design_model(data, design, verbose = FALSE)
model=attr(dadm, "model")()
pars <- get_pars_matrix(p_vector, dadm, model)
