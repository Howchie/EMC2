lapply(Packages, library, character.only = TRUE) # to install change 'library' to 'install.packages'
# set directory to source file location -- the location of this script is our "base" folder
source("Functions.R")
source("Contrasts.R")
## Read in Eidels 2015 data
load("Eidels2015.RData"); all_data_acc$UC=4; data=all_data_acc
# Functions used for design
ContrastFun <- function(d)factor(paste(d$lR,d$S,d$LogicalRule,sep="."),levels=row.names(rate_design))
i="BJ"
data=all_data_acc[all_data_acc$subjects==i,]
data$subjects=factor(data$subjects)
design1 <- design(
fixed_accumulator_roles = factor(c("A","n_A","B","n_B","n_A_flip","n_B_flip"),levels=c("A","n_A","B","n_B","n_A_flip","n_B_flip")),
matchfun=matchfun,
model=LogicalRulesLBA_negdrift,constants=c(v=0,B=0,sv=0,A=0,sv_SVsmismatchN_UT=log(1),sv_SVsmismatchN_LT=log(1),v_RateContrastguess=0,B_Thresholdsguess=0,A_StartPointsguess=0,sv_SVsguess=0),
formula=list(v~RateContrast,B~Thresholds,t0~1,A~StartPoints,sv~SVs),
functions=list(nDots=nTargets_Contrast,Capacity=Capacity_Contrast,
RateContrast=ContrastFun,Thresholds=ContrastFun,SVs=ContrastFun,StartPoints=ContrastFun),
contrasts=list(v=list(RateContrast=rate_design_reduced),B=list(Thresholds=threshold_design), sv=list(SVs=sv_design), A=list(StartPoints=A_design)),
data=data
)
