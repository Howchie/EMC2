geom_point(data = points_data,
aes(x = S, y = Accuracy, shape = LogicalRule),
size = 2, fill = "white") +
theme_bw(base_size = 14) +
labs(
title = "Accuracy",
y = "Accuracy",
x = "S"
) +
scale_shape_manual(values = c(21, 24, 22, 23)) +
scale_color_brewer(palette = "Set1") +
theme(
legend.position = "top",
strip.background = element_blank(),
panel.grid.minor = element_blank()
) + ylim(.5,1.00)
# ## Script to simulate from, and test recovery of, RDMSWTN
# rm(list=ls())
# Packages <- c("rstudioapi","EMC2","tidyr","dplyr","sft","ggplot2")
# lapply(Packages, library, character.only = TRUE) # to install change 'library' to 'install.packages'
# # set directory to source file location -- the location of this script is our "base" folder
# source("Functions.R")
# source("Contrasts.R")
# ## Read in Eidels 2015 data
# load("Eidels2015.RData"); data=all_data_acc
#
#
# designBushmakin <- design(
#   fixed_accumulator_roles = factor(c("A","n_A","B","n_B"),levels=c("A","n_A","B","n_B")),
#   matchfun=matchfun,
#   model=LogicalRules,constants=c('sv_lMFALSE:LogicalRuleAND'=log(1),'sv_lMFALSE:LogicalRuleOR'=log(1)),
#   formula=list(v~0+Stim,B~(0+Resp:LogicalRule),t0~0+LogicalRule,A~0+LogicalRule,sv~0+lM:LogicalRule,p~0+LogicalRule,q~0+LogicalRule),
#   functions=list(Stim=RateYNMatchMismatch_Contrast,Resp=YN_Contrast,nDots=nTargets_Contrast),
#   data=data
# )
# Set Priors
p_vector <- sampled_pars(designBushmakin,doMap=FALSE)
p_vector["v_StimNA_AND"] = 1.7
p_vector["v_StimNA_OR"] = 1.5
p_vector["v_StimNP_AND"] = .58
p_vector["v_StimNP_OR"] = -1.5
p_vector["v_StimYA_AND"] = -1.2
p_vector["v_StimYA_OR"] = -2.5
p_vector["v_StimYP_AND"] = 2.9
p_vector["v_StimYP_OR"] = 1.5
p_vector["B_RespY:LogicalRuleAND"] = log(1)
p_vector["B_RespY:LogicalRuleOR"] = log(0.55)
p_vector["B_RespN:LogicalRuleAND"] = log(.77)
p_vector["B_RespN:LogicalRuleOR"] =  log(.68)
p_vector["sv_lMTRUE:LogicalRuleAND"] = log(.96)
p_vector["sv_lMTRUE:LogicalRuleOR"] = log(0.74)
p_vector["t0_LogicalRuleOR"] = log(.1)
p_vector["t0_LogicalRuleAND"] = log(.084)
p_vector["A_LogicalRuleOR"] = log(.035)
p_vector["A_LogicalRuleAND"] = log(.6)
p_vector["p_LogicalRuleOR"] =  qnorm(0.59)
p_vector["q_LogicalRuleOR"] = qnorm(1-0.048)
p_vector["p_LogicalRuleAND"] =  qnorm(0.92)
p_vector["q_LogicalRuleAND"] = qnorm(1-0.029)
designHoward <- design(
fixed_accumulator_roles = factor(c("A","n_A","B","n_B"),levels=c("A","n_A","B","n_B")),
matchfun=matchfun,
model=LogicalRules,constants=c('sv_lMFALSE:LogicalRuleAND'=log(1),'sv_lMFALSE:LogicalRuleOR'=log(1),p=qnorm(1),q=qnorm(0.5)),
formula=list(v~0+Stim:Location,B~(0+Resp:LogicalRule:Location),t0~0+nDots,A~0+LogicalRule,sv~0+lM:LogicalRule,p~1,q~1),
functions=list(Stim=RateYNMatchMismatch_Contrast,Resp=YN_Contrast,nDots=nTargets_Contrast,Location=Threshold_Location_Contrast),
data=data
)
# Set Priors
p_vector2 <- sampled_pars(designHoward,doMap=FALSE)
p_vector2["v_StimMatchNA_AND:LocationUT"] = 2.037
p_vector2["v_StimMatchNA_OR:LocationUT"] = 1.589
p_vector2["v_StimMatchYP_AND:LocationUT"] = 2.352
p_vector2["v_StimMatchYP_OR:LocationUT"] = 1.271
p_vector2["v_StimMismatchYA_AND:LocationUT"] = 0.863
p_vector2["v_StimMismatchYA_OR:LocationUT"] = -4.325
p_vector2["v_StimMismatchNP_AND:LocationUT"] = 0.705
p_vector2["v_StimMismatchNP_OR:LocationUT"] = 1.405
p_vector2["v_StimMatchNA_AND:LocationLT"] = 2.037
p_vector2["v_StimMatchNA_OR:LocationLT"] = 1.589
p_vector2["v_StimMatchYP_AND:LocationLT"] = 2.352
p_vector2["v_StimMatchYP_OR:LocationLT"] = 1.271
p_vector2["v_StimMismatchYA_AND:LocationLT"] = 0.863
p_vector2["v_StimMismatchYA_OR:LocationLT"] = -4.325
p_vector2["v_StimMismatchNP_AND:LocationLT"] = 0.705
p_vector2["v_StimMismatchNP_OR:LocationLT"] = 1.405
p_vector2["B_RespY:LogicalRuleAND:LocationUT"] = log(.528)
p_vector2["B_RespY:LogicalRuleAND:LocationLT"] = log(.638)
p_vector2["B_RespN:LogicalRuleAND:LocationUT"] = log(.635)
p_vector2["B_RespN:LogicalRuleAND:LocationLT"] =  log(.602)
p_vector2["B_RespY:LogicalRuleOR:LocationUT"] = log(.308)
p_vector2["B_RespY:LogicalRuleOR:LocationLT"] = log(.27)
p_vector2["B_RespN:LogicalRuleOR:LocationUT"] = log(.787)
p_vector2["B_RespN:LogicalRuleOR:LocationLT"] =  log(.596)
p_vector2["sv_lMTRUE:LogicalRuleAND"] = log(0.509)
p_vector2["sv_lMTRUE:LogicalRuleOR"] = log(0.509)
p_vector2["t0_nDots0T"] = log(.405)
p_vector2["t0_nDots1T"] = log(.4)
p_vector2["t0_nDots2T"] = log(.373)
p_vector2["A_LogicalRuleOR"] = log(.39)
p_vector2["A_LogicalRuleAND"] = log(.22)
pred = make_data(p_vector2,designHoward,n_trials=100)
# Check likelihood
#dadm <- design_model(pred,designBushmakin)
#pars <- get_pars_matrix(p_vector, dadm, model = attr(dadm, "model")())
## Plotting
quantiles <- c(.1,.5,.9)#seq(from=0.05,to=0.95,by=0.05)
design_cells=data.frame(label=factor(levels(interaction(data$S,data$LogicalRule))))
pred$Correct=correctfun(pred);data$Correct=correctfun(data)
pred=pred[pred$rt<4,]
# Extract Quantiles by Design Cell x PM_trial x Correct
plotdata <- purrr::map_dfr(design_cells$label, function(lbl) {
parts <- strsplit(as.character(lbl), "\\.")[[1]]
names(parts) <- c("S", "LogicalRule")
compute_quantile_points_by_subject(
data_obs = data,
data_pred = pred,
factors = list(S = parts["S"], LogicalRule = parts["LogicalRule"]),
design_label = lbl,
correct_col = "Correct",
quantiles=quantiles,
group_level=TRUE
)
}) %>%
group_by(Quantile, Source, Subset, DesignCell) %>%
summarise(
RT_mean = mean(RT, na.rm = TRUE),
.groups = "drop"
) %>%
separate(DesignCell, into = c("S", "LogicalRule"), sep = "\\.",remove = FALSE) %>%
mutate(S=factor(S,levels=c("DT","UT","LT","NT")),LogicalRule=factor(LogicalRule,levels=c("AND","OR"))) %>%
arrange(LogicalRule,S) %>%
as.data.frame()
# Add any needed columns for grouping/factors
group_vars <- c("S", "LogicalRule", "Correct")
# Calculate quantiles per draw per group
pred_quantiles <- pred %>%
group_by(across(all_of(group_vars))) %>%
summarise(
quantile_vals = list(quantile(rt, probs = quantiles, na.rm = TRUE)),
.groups = "drop"
) %>%
unnest_wider(quantile_vals, names_sep = "_") %>%
pivot_longer(
starts_with("quantile_vals_"),
names_to = "Quantile",
names_prefix = "quantile_vals_",
values_to = "RT"
) %>%
mutate(Quantile = as.numeric(gsub("%", "", Quantile)) / 100) %>%
group_by(S, LogicalRule, Correct, Quantile) %>%
summarise(
RT_mean = mean(RT, na.rm = TRUE),
RT_lower = quantile(RT, 0.025, na.rm = TRUE),
RT_upper = quantile(RT, 0.975, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(Source="Recovered") %>%
filter(Correct==TRUE) %>%
bind_rows(data %>%
group_by(across(all_of(group_vars))) %>%
summarise(
quantile_vals = list(quantile(rt, probs = quantiles, na.rm = TRUE)),
.groups = "drop"
) %>%
unnest_wider(quantile_vals, names_sep = "_") %>%
pivot_longer(
starts_with("quantile_vals_"),
names_to = "Quantile",
names_prefix = "quantile_vals_",
values_to = "RT"
) %>%
mutate(Quantile = as.numeric(gsub("%", "", Quantile)) / 100) %>%
group_by(S, LogicalRule, Correct, Quantile) %>%
summarise(
RT_mean = mean(RT, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(Source="Data") %>%
filter(Correct==TRUE))
# Extract Quantiles by Design Cell x PM_trial x Correct
accuracy_data <- purrr::map_dfr(design_cells$label, function(lbl) {
parts <- strsplit(as.character(lbl), "\\.")[[1]]
names(parts) <- c("S", "LogicalRule")
compute_accuracy_by_subject(
data_obs = data,
data_pred = pred,
factors = list(S = parts["S"], LogicalRule = parts["LogicalRule"]),
design_label = lbl,
correct_col = "Correct",
group_level=TRUE
)
}) %>%
group_by(Source, Subset, DesignCell) %>%
summarise(
Accuracy = mean(Accuracy),
.groups = "drop"
) %>%
separate(DesignCell, into = c("S", "LogicalRule"), sep = "\\.",remove = FALSE) %>%
mutate(S=factor(S,levels=c("DT","UT","LT","NT")),LogicalRule=factor(LogicalRule,levels=c("AND","OR"))) %>%
arrange(LogicalRule,S) %>%
as.data.frame()
# Filtered subsets for clarity
plotdata_correct <- plotdata[plotdata$Subset == "correct", ]
# Lines: only for "Recovered"
lines_data <- subset(plotdata_correct, Source == "Recovered")
# Points: only for "Observed"
points_data <- subset(plotdata_correct, Source == "Data")
ggplot() +
# Lines for "Recovered"
geom_line(data = lines_data,
aes(x = S, y = RT_mean, group = interaction(Quantile,LogicalRule)),
size = 1) +
# Points for "Observed"
geom_point(data = plotdata_correct,
aes(x = S, y = RT_mean, shape = interaction(LogicalRule,Source)),
size = 3, fill = "white") +
theme_bw(base_size = 14) +
# geom_errorbar(
#   data =pred_quantiles,
#   aes(x = S, ymin = RT_lower, ymax = RT_upper, group = interaction(Quantile, LogicalRule)),
#   width = 0.1
# ) +
labs(
title = "RTs",
y = "RT (s)",
x = "Quantile"
) +
facet_wrap(~LogicalRule) +
scale_shape_manual(values = c(21, 24, 22, 23)) +
scale_color_brewer(palette = "Set1") +
theme(
legend.position = "top",
strip.background = element_blank(),
panel.grid.minor = element_blank()
) + ylim(0.3,1.3)
## Accuracy Data
# Lines: only for "Recovered"
lines_data <- subset(accuracy_data, Source == "Recovered")
# Points: only for "Observed"
points_data <- subset(accuracy_data, Source == "Data")
ggplot() +
# Lines for "Recovered"
geom_line(data = lines_data,
aes(x = S, y = Accuracy, linetype = LogicalRule, group = interaction(Source,LogicalRule)),
size = 1) +
# Points for "Observed"
geom_point(data = points_data,
aes(x = S, y = Accuracy, shape = LogicalRule),
size = 2, fill = "white") +
theme_bw(base_size = 14) +
labs(
title = "Accuracy",
y = "Accuracy",
x = "S"
) +
scale_shape_manual(values = c(21, 24, 22, 23)) +
scale_color_brewer(palette = "Set1") +
theme(
legend.position = "top",
strip.background = element_blank(),
panel.grid.minor = element_blank()
) + ylim(.5,1.00)
