# Parameters
lambda <- 1
theta  <- .8
sigma  <- .5
z0     <- 3
b      <- 1
c = sqrt(lambda) / sigma
z_scaled = c * (z0 - theta)
b_scaled = c * (b - theta)
t_vec = seq(0.05,3,length.out=10)
for(i in t_vec) {
test = ou_fht_pdf_forward_debug(i,lambda, theta, sigma, z0, b, num_steps = 300)
pdfs = c(
"A_trap" = (test$termA-(test$termB*test$nu_f_at_theta_block)+test$prefactor*test$A_trap)*test$lambda,
"B_trap" = (test$termA-(test$termB*test$nu_f_at_tau_grid)+test$prefactor*test$B_trap)*test$lambda,
"C_trap" = (test$termA-(test$termB*test$nu_f_at_tau_block)+test$prefactor*test$C_trap)*test$lambda,
"D_trap" = (test$termA-(test$termB*test$nu_f_at_tau_grid_uniform)+test$prefactor*test$D_trap)*test$lambda,
"A_u" = (test$termA-(test$termB*test$nu_f_at_theta_block)+test$prefactor*test$A_u)*test$lambda,
"B_u" = (test$termA-(test$termB*test$nu_f_at_tau_grid)+test$prefactor*test$B_u)*test$lambda,
"C_u" = (test$termA-(test$termB*test$nu_f_at_tau_block)+test$prefactor*test$C_u)*test$lambda,
"D_u" = (test$termA-(test$termB*test$nu_f_at_tau_grid_uniform)+test$prefactor*test$D_u)*test$lambda,
"reference" = ou_fht_pdf_from_cdf_regularized(i,lambda, theta, sigma, z0, b, num_steps = 300)
)
tau_grid <- test$tau_vals_grid
nu_vals  <- test$nu_f_vals_tau_grid
nu_tau   <- tail(nu_vals, 1)                     # consistent ν(τ)
b_scaled <- test$b_scaled
tau      <- test$tau
e2t      <- test$e2t
lambda   <- test$lambda
g_gt <- pdfs["reference"]
t_scaled <- test$t_scaled            # = λ * t
# or prod$I; they match
prod <- integrate_pdf_product_R(tau, tau_grid, nu_vals, b_scaled)
ref  <- integrate_pdf_ref_R(tau, tau_grid, nu_vals, b_scaled, K_panel = 800L)
# recompute A,B from raw scalars (ignore any termA/termB naming)
AB  <- AB_from_tstar(t_scaled, b_scaled, z_scaled)
A   <- AB$A
Bc  <- AB$Bcoeff
e2t <- AB$e2t
Ineed <- I_needed(g_gt = pdfs["reference"], lambda=lambda,
A=A, Bcoeff=Bc, nu_tau=nu_tau, e2t=e2t)
I_num    <- ref$I
g_hat <- predict_pdf_from_I(I_num, lambda, A, Bc, nu_tau, e2t)
cat(sprintf("I_needed = %.9g | I_num = %.9g | ratio = %.3f\n",
Ineed, I_num, I_num/Ineed))
cat(sprintf("pdf_gt = %.9g | pdf_pred_from_I = %.9g | abs diff = %.3g\n",
pdfs["reference"], g_hat, abs(pdfs["reference"] - g_hat)))
}
