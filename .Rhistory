library(EMC2)
RNGkind("L'Ecuyer-CMRG")
set.seed(123)
# Sys.setenv(PAR_DEBUG = "1")   # turn serial mode on
# if (identical(Sys.getenv("PAR_DEBUG"), "1")) {      # opt-in via env-var
#   env <- asNamespace("parallel")
