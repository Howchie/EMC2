#   }, envir = env)
#   lockBinding("parLapply", env)
# }
## Set simulation parameters:
nsubs=1; ntrials=2000
## For maximum testing purposes we'll simulate from a model with varying n_acc
matchfun <- function(d) as.numeric(d$S)==as.numeric(d$lR)
designLBA <- design(
factors=list(subjects=1:nsubs,S=c("yes"), block=c("low","high")),
Rlevels=c("yes"),
matchfun=matchfun,
model=LBAIO,constants=c(B=log(1)),
formula=list(v~0+block,B~1,t0~1,A~1,sv~0+block,pContaminant~1),
)
p_vector <- sampled_pars(designLBA,doMap = FALSE)
p_vector[1:length(p_vector)] <- c(2,1,log(0.2),log(0.5),log(1),log(1),qnorm(0.2))
mapped_pars(designLBA,p_vector)
# Make square data so can remove pm in RACE = 2
template <- make_data(p_vector,designLBA,n_trials=ntrials,UC=4)
dat <- make_data(p_vector,designLBA,data=template)
p_names = names(sampled_pars(designLBA))
emc <- make_emc(dat,designLBA,type="single")
emc <- fit(emc,cores_for_chains = 3,fileName = 'samples.RData')
get_pars(emc,merge_chains=TRUE,return_mcmc = FALSE)[,,1000]
pred = predict(emc)
mean(is.na(dat$R[dat$block=="low"]));mean(is.na(pred$R[pred$block=="low"]))
mean(is.na(dat$R[dat$block=="high"]));mean(is.na(pred$R[pred$block=="high"]))
quantile(dat$rt[is.finite(dat$rt)&dat$block=="low"],na.rm=TRUE)
quantile(dat$rt[is.finite(dat$rt)&dat$block=="high"],na.rm=TRUE)
quantile(pred$rt[is.finite(pred$rt)&pred$block=="low"],na.rm=TRUE)
quantile(pred$rt[is.finite(pred$rt)&pred$block=="high"],na.rm=TRUE)
pRTR=0.6
pRT=0.6
pTO=0.2
pC=0.2
(1-pC)*pRT
exp(log1p(-pC)+log(pRT))
log(sum(1-pC,pTO))
(1-pC)*pTO
log(sum(pC,(1-pC)*pTO))
sum(pC,(1-pC)*pTO)
exp(log1p(-pC)+log(pTO))+pC
designLBA <- design(
factors=list(subjects=1:nsubs,S=c("yes"), block=c("low","high")),
Rlevels=c("yes"),
